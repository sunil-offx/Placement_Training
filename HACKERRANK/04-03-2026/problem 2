import java.util.*;

public class Solution {

    public static boolean canWin(int leap, int[] game, int i) {
        int n = game.length;

        // If index is beyond array, player wins
        if (i >= n) {
            return true;
        }

        // Invalid move
        if (i < 0 || game[i] == 1) {
            return false;
        }

        // Mark as visited
        game[i] = 1;

        // Try leap, forward, and backward moves
        return canWin(leap, game, i + leap) ||
               canWin(leap, game, i + 1) ||
               canWin(leap, game, i - 1);
    }

    public static boolean canWin(int leap, int[] game) {
        return canWin(leap, game, 0);
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int q = sc.nextInt();

        while (q-- > 0) {
            int n = sc.nextInt();
            int leap = sc.nextInt();

            int[] game = new int[n];

            for (int i = 0; i < n; i++) {
                game[i] = sc.nextInt();
            }

            if (canWin(leap, game)) {
                System.out.println("YES");
            } else {
                System.out.println("NO");
            }
        }
    }
}
